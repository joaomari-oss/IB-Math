# ══════════════════════════════════════════════════════════
#  IB Math Tutor — Template de Configuração
#  Copie este arquivo para .env e preencha suas chaves
# ══════════════════════════════════════════════════════════

# Groq (GRATUITO — https://console.groq.com)
GROQ_API_KEY=SUA_CHAVE_AQUI

# Google Gemini (GRATUITO — https://aistudio.google.com/apikey)
# GEMINI_API_KEY=SUA_CHAVE_AQUI

# Provedor: groq ou gemini
AI_PROVIDER=groq

# Origens liberadas para usar o chat (separe por vírgula em produção)
# Exemplo: https://joaomari-oss.github.io,https://seu-dominio.com
ALLOWED_ORIGINS=https://joaomari-oss.github.io

# Porta
PORT=3001
